# Codex CLI config for the cross-family adversary — copy to ~/.codex/config.toml (or .codex/config.toml
# in a trusted project) and fill in YOUR own MCP servers (mirror the ones your .mcp.json declares).
#
# The adversary is an EYE, never a hand: it inspects and judges, it never mutates. The read-only
# sandbox enforces that — Codex cannot write, run destructive commands, or touch state.

# Read-only by default: the adversary inspects; it never edits.
sandbox_mode = "read-only"
approval_policy = "never"        # non-interactive: codex exec must not prompt

# Optional: pin a strong reasoning model for the attack (subscription or API key, per your login).
# model = "gpt-5"

# --- MCP servers: mirror the SAME servers Claude uses, so the Codex adversary inspects with the
# --- same context. Each table is one server. Leave empty to run with no MCP (bridge still works).
#
# [mcp_servers.example]
# command = "npx"
# args = ["-y", "@some/mcp-server"]
# env = { SOME_TOKEN = "..." }    # provide YOUR own credentials — never commit real secrets

# A dedicated profile keeps the adversary settings isolated from your day-to-day Codex use.
[profiles.adversary]
sandbox_mode = "read-only"
approval_policy = "never"
